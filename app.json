{
  "expo": {
    "name": "FinApp",
    "slug": "fin-app-mobile",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "finapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.amitil13.finappmobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-updates"],
    "runtimeVersion": "1.0.0",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2c183182-669e-49b1-b3e2-fece897e7987"
      }
    },
    "owner": "amitil13",
    "updates": {
      "url": "https://u.expo.dev/2c183182-669e-49b1-b3e2-fece897e7987"
    }
  }
}
